# Let Git normalize text files in the repository.
* text=auto

# Visual Studio C/C++ files use Windows line endings in the working tree.
*.c           text eol=crlf
*.cc          text eol=crlf
*.cpp         text eol=crlf
*.cxx         text eol=crlf
*.h           text eol=crlf
*.hh          text eol=crlf
*.hpp         text eol=crlf
*.hxx         text eol=crlf
*.inl         text eol=crlf
*.sln         text eol=crlf
*.slnx        text eol=crlf
*.vcxproj     text eol=crlf
*.filters     text eol=crlf
*.props       text eol=crlf
*.targets     text eol=crlf

# Repository metadata stays platform-neutral.
.gitattributes text eol=lf
.gitignore     text eol=lf
*.md           text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
